{
  "info": {
    "name": "Grupo 7 - Products y Categories API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "product_id",
      "value": "1"
    },
    {
      "key": "category_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": {\n    \"name\": \"Tecnologia\",\n    \"description\": \"Productos electronicos y accesorios.\"\n  }\n}"
            }
          }
        },
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/categories"
          }
        },
        {
          "name": "Get category by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        },
        {
          "name": "Update category",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/categories/{{category_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": {\n    \"description\": \"Productos electronicos actualizados.\"\n  }\n}"
            }
          }
        },
        {
          "name": "Delete category",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/categories/{{category_id}}"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/products",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": {\n    \"name\": \"Teclado mecanico\",\n    \"description\": \"Teclado USB con switches mecanicos.\",\n    \"price\": 49.99,\n    \"stock\": 15,\n    \"category_id\": {{category_id}}\n  }\n}"
            }
          }
        },
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products"
          }
        },
        {
          "name": "Search and filter products",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products?q=teclado&min_price=10&max_price=100&in_stock=true"
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/products/{{product_id}}"
          }
        },
        {
          "name": "Update product",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/products/{{product_id}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product\": {\n    \"name\": \"Teclado mecanico RGB\",\n    \"price\": 54.99,\n    \"stock\": 12\n  }\n}"
            }
          }
        },
        {
          "name": "Delete product",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/products/{{product_id}}"
          }
        }
      ]
    }
  ]
}
