                  "pm.test(\"Estado HTTP 201\", function () {\r\n  pm.response.to.have.status(201);\r\n});\r\n\r\npm.test(\"Usuario registrado correctamente\", function () {\r\n  const json = pm.response.json();\r\n\r\n  pm.expect(json.message).to.eql(\r\n    \"Usuario registrado correctamente\"\r\n  );\r\n\r\n  pm.expect(json.data.userId).to.exist;\r\n  pm.expect(json.data.email).to.eql(\r\n    \"scarlett.postman@correo.com\"\r\n  );\r\n});\r\n\r\npm.test(\"La contraseña no aparece en la respuesta\", function () {\r\n  const responseText = pm.response.text();\r\n\r\n  pm.expect(responseText).to.not.include(\"password_digest\");\r\n  pm.expect(responseText).to.not.include(\"Clave123*\");\r\n});"
